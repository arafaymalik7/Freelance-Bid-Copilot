{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Freelancer Bid Copilot",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build:index": "cross-env BIDCOPILOT_INDEX_BUILD=true node scripts/buildVectorIndex.js",
    "test": "jest --runInBand",
    "test:live": "cross-env LIVE_GEMINI_TESTS=1 jest --runInBand --testPathPatterns=pipeline.live",
    "test:live:workspace": "cross-env LIVE_GEMINI_TESTS=1 jest --runInBand --testPathPatterns=workspace.live"
  },
  "keywords": [
    "express",
    "gemini",
    "freelance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
